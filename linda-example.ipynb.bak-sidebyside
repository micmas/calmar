    "        <b>WAB decomposition</b>: flu = fluency, comp = comprehension, rep = repetition.\n",
    "        <span style=\"color:#2e7d32\">+</span> preserved,\n",
    "        <span style=\"color:#c62828\">&#8722;</span> impaired.\n",
    "      </div>\n",
    "    </div>\n",
    "    '''\n",
    "    display(HTML(html))\n"
